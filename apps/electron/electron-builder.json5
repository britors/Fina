{
  appId: "com.britors.fina",
  productName: "Fina",
  copyright: "Copyright © 2026 Rodrigo Brito",

  directories: {
    output: "dist",
    buildResources: "build"
  },

  // Arquivos incluídos no pacote
  files: [
    "out/**/*",
    "package.json"
  ],

  // Rebuild de módulos nativos (better-sqlite3-multiple-ciphers) para o Electron alvo
  npmRebuild: true,

  // Feed do electron-updater (usado apenas no Windows — ver src/main/updater.ts)
  publish: {
    provider: "github",
    owner: "britors",
    repo: "Fina"
  },

  linux: {
    target: ["deb", "rpm"],
    category: "Office",
    synopsis: "Gerenciador de finanças pessoais",
    description: "Controle total das suas finanças: meios de pagamento, transações, orçamentos, investimentos, metas e muito mais.",
    // build/icons/ (conjunto hicolor 16→1024) gerado por npm run generate-icons.
    // Um único PNG grande deixa o .deb/.rpm com só um tamanho de ícone, que
    // ambientes como o KDE não escalam bem para o menu/barra de tarefas.
    icon: "build/icons"
  },

  deb: {
    depends: ["libsecret-1-0", "libgtk-3-0", "libnotify4", "libnss3", "libxtst6"]
  },

  rpm: {
    depends: ["libsecret", "gtk3", "libnotify", "nss", "libXtst"],
    // Evita gerar symlinks /usr/lib/.build-id/... para os binários do Electron
    // empacotados sem recompilação. Como esses binários são idênticos aos de
    // outros apps Electron (mesmo build-id), os symlinks colidem entre pacotes
    // não relacionados na instalação (ex.: conflito com o pacote "prosa").
    fpm: ["--rpm-rpmbuild-define", "_build_id_links none"]
  },

  win: {
    target: [{ target: "nsis", arch: ["x64"] }],
    // build/icon.ico gerado por npm run generate-icons
    icon: "build/icon.ico",
    // Nome fixo (sem espaços) — precisa bater com o asset que o release.yml
    // sobe no GitHub Release, pois é esse nome que o latest.yml referencia
    // e que o electron-updater usa para baixar o instalador.
    artifactName: "Fina-Setup-${version}.${ext}"
  },

  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true,
    createDesktopShortcut: true,
    createStartMenuShortcut: true,
    shortcutName: "Fina"
  }
}
