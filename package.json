{
  "name": "fina-desktop",
  "version": "17.9.0",
  "private": true,
  "description": "Fina desktop para Windows, macOS e Linux",
  "workspaces": [
    "apps/electron"
  ],
  "scripts": {
    "build": "npm run build:electron",
    "build:electron": "npm --workspace @fina/electron run build",
    "start": "npm run start:electron",
    "start:electron": "npm --workspace @fina/electron run start",
    "test": "npm run test:electron",
    "test:electron": "npm --workspace @fina/electron run test",
    "typecheck": "npm --workspace @fina/electron run typecheck",
    "dist": "npm --workspace @fina/electron run dist",
    "dist:linux": "npm --workspace @fina/electron run dist:linux",
    "dist:win": "npm --workspace @fina/electron run dist:win",
    "generate-icons": "npm --workspace @fina/electron run generate-icons"
  }
}
