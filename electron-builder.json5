{
  appId: "com.britors.fina",
  productName: "Fina",
  copyright: "Copyright © 2026 Rodrigo Brito",

  directories: {
    output: "dist",
    buildResources: "build"
  },

  // Arquivos incluídos no pacote
  files: [
    "out/**/*",
    "package.json"
  ],

  // Rebuild de módulos nativos (better-sqlite3) para o Electron alvo
  npmRebuild: true,

  linux: {
    target: ["deb", "rpm"],
    category: "Office",
    synopsis: "Gerenciador de finanças pessoais",
    description: "Controle total das suas finanças: contas, transações, orçamentos, investimentos, metas e muito mais.",
    // build/icon.png gerado por npm run generate-icons
    icon: "build/icon.png"
  },

  deb: {
    depends: ["libsecret-1-0", "libgtk-3-0", "libnotify4", "libnss3", "libxtst6"]
  },

  rpm: {
    depends: ["libsecret", "gtk3", "libnotify", "nss", "libXtst"]
  },

  win: {
    target: [{ target: "nsis", arch: ["x64"] }],
    // build/icon.ico gerado por npm run generate-icons
    icon: "build/icon.ico"
  },

  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true,
    createDesktopShortcut: true,
    createStartMenuShortcut: true,
    shortcutName: "Fina"
  }
}
